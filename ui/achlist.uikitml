<panel>
  <style>
    .root {
      width: 550;
      height: 600;
      background-color: rgba(5, 5, 20, 0.95);
      border-radius: 16;
      padding: 20;
      flex-direction: column;
      align-items: center;
      gap: 6;
      border-color: #ffaa00;
      border-width: 2;
      overflow: scroll;
    }
    .title {
      font-size: 28;
      color: #ffaa00;
      font-weight: bold;
    }
    .ach-item {
      width: 480;
      flex-direction: column;
      padding: 8;
      border-radius: 6;
      background-color: #1a1a2e;
    }
    .ach-name {
      font-size: 16;
      color: #ffcc00;
      font-weight: bold;
    }
    .ach-desc {
      font-size: 12;
      color: #888899;
    }
    .back-btn {
      width: 200;
      height: 40;
      background-color: #1a1a3e;
      border-radius: 8;
      justify-content: center;
      align-items: center;
      border-color: #666688;
      border-width: 1;
      cursor: pointer;
      margin-top: 8;
    }
    .back-text {
      font-size: 16;
      color: #888899;
    }
  </style>
  <container class="root">
    <text class="title">ACHIEVEMENTS</text>
    <container class="ach-item" name="ach-0-bg"><text class="ach-name" name="ach-0-name">???</text><text class="ach-desc" name="ach-0-desc">Locked</text></container>
    <container class="ach-item" name="ach-1-bg"><text class="ach-name" name="ach-1-name">???</text><text class="ach-desc" name="ach-1-desc">Locked</text></container>
