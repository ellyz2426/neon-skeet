    <container class="ach-item" name="ach-27-bg"><text class="ach-name" name="ach-27-name">???</text><text class="ach-desc" name="ach-27-desc">Locked</text></container>
    <container class="ach-item" name="ach-28-bg"><text class="ach-name" name="ach-28-name">???</text><text class="ach-desc" name="ach-28-desc">Locked</text></container>
    <container class="ach-item" name="ach-29-bg"><text class="ach-name" name="ach-29-name">???</text><text class="ach-desc" name="ach-29-desc">Locked</text></container>
    <container class="back-btn" name="btn-back-ach">
      <text class="back-text">BACK</text>
    </container>
  </container>
</panel>
